{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/webhook/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/demos/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/success",
      "dest": "/server.js"
    },
    {
      "src": "/error",
      "dest": "/server.js"
    },
    {
      "src": "/",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
